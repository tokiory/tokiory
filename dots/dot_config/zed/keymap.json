// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run zed: open default keymap
// from the command palette.

[
  // Global keybindings
  {
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-u": "git::FileHistory",
      "cmd-shift-j": "terminal_panel::ToggleFocus",
    },
  },

  // Vim keybindings
  {
    "context": "Editor && VimControl",
    "bindings": {
      "g f": "editor::Format",
      "space v": "project_panel::ToggleFocus",
      "space g": "git_panel::ToggleFocus",
    },
  },

  // I am freak, I'm used to confirming the auto compliance via Ctrl + Y, so here it is
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCompletion",
    },
  },

  // Git keybindings
  {
    "context": "GitPanel",
    "bindings": {
      "ctrl-g p": "git::Push",
      "ctrl-g P": "git::ForcePush",
      "ctrl-g u": "git::Pull",
      "ctrl-g f": "git::Fetch",
    },
  },

  // Terminal keybindings
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal",
      "cmd-n": "workspace::NewTerminal",
      "cmd-d": "pane::CloseActiveItem",
    },
  },

  // Pane keybindings
  {
    "context": "Pane",
    "bindings": {
      "ctrl-1": ["workspace::ActivatePane", 0],
      "ctrl-2": ["workspace::ActivatePane", 1],
      "ctrl-3": ["workspace::ActivatePane", 2],
      "ctrl-4": ["workspace::ActivatePane", 3],
      "ctrl-5": ["workspace::ActivatePane", 4],
      "ctrl-6": ["workspace::ActivatePane", 5],
      "ctrl-7": ["workspace::ActivatePane", 6],
      "ctrl-8": ["workspace::ActivatePane", 7],
      "ctrl-9": ["workspace::ActivatePane", 8],
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-b": "git::CheckoutBranch",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-|": null,
    },
  },
  {
    "bindings": {
      "cmd-|": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-cmd-c": "workspace::CopyRelativePath"
    }
  },
  {
    "bindings": {
      "ctrl-cmd-c": null
    }
  },
  {
    "bindings": {
      "cmd-?": "agent::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "cmd-shift-k": "agent::ExpandMessageEditor"
    }
  }
]
